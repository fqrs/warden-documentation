{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Warden",
  "description": "Documentation for Warden — the Discord bot built for ER:LC community management.",
  "colors": {
    "primary": "#3646F5",
    "light": "#6B8CFF",
    "dark": "#1D29C4"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "light": "#3646F5",
      "dark": "#1D29C4"
    }
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "pages": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "configuration/getting-started",
          "modules/configuration"
        ]
      },
      {
        "group": "Setup & reference",
        "pages": [
          "configuration/erlc-integration",
          "configuration/commands",
          "configuration/variables",
          "modules/permissions"
        ]
      },
      {
        "group": "Modules",
        "pages": [
          {
            "group": "In-game & live ops",
            "pages": [
              "modules/roblox-moderation",
              "modules/erlc-logs",
              "modules/sessions"
            ]
          },
          {
            "group": "Staff & community",
            "pages": [
              "modules/shift-logging",
              "modules/infractions",
              "modules/staff-feedback",
              "modules/verification",
              "modules/applications"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Invite Warden",
          "href": "https://discord.com/oauth2/authorize?client_id=1506630562113130657",
          "icon": "discord"
        },
        {
          "anchor": "Support Server",
          "href": "https://discord.gg/9mKPyknj8z",
          "icon": "life-ring"
        },
        {
          "anchor": "Website",
          "href": "https://wrdnbot.xyz",
          "icon": "globe"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/warden.png",
    "dark": "/logo/warden.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://wrdnbot.xyz"
      },
      {
        "label": "Support Server",
        "href": "https://discord.gg/9mKPyknj8z"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Invite Warden",
      "href": "https://discord.com/oauth2/authorize?client_id=1506630562113130657"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/9mKPyknj8z"
    }
  }
}
